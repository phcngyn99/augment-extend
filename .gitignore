# Augment Extend — Git Sync Configuration
#
# Philosophy: Shared config (rules/skills/agents) syncs via git.
# Personal data (sessions/settings/state) stays local.
#
# Safe workflow:
#   cd ~/.augment && git pull  # Updates shared config, preserves local data

# ── Auth and Session Data (machine-specific) ──────────────────────────────────
session.json
session.json.*
.auggie.json

# ── User Settings (machine-specific — use settings.json.template) ─────────────
settings.json
settings.json.backup

# ── Runtime and State ──────────────────────────────────────────────────────────
sessions/
prompt-history.jsonl
task-storage/

# ── Checkpoints (local only) ──────────────────────────────────────────────────
checkpoint-documents/

# ── Context Keeper Data (local only) ──────────────────────────────────────────
ck/contexts/
ck/current-session.json
ck/projects.json

# ── Native Memory (local only) ─────────────────────────────────────────────────
projects/

# ── Untruncated Cache (local only) ─────────────────────────────────────────────
untruncated/

# ── Skill Library Cache (local only) ───────────────────────────────────────────
skill-library/

# ── CodeGraph Index (local only) ───────────────────────────────────────────────
.codegraph/

# ── Binaries (platform-specific) ───────────────────────────────────────────────
binaries/

# ── Backups ────────────────────────────────────────────────────────────────────
*.backup

# ── Homunculus Project State (local only) ──────────────────────────────────────
homunculus/

# ── Marketplace Repos (clone separately per INSTALL.md) ────────────────────────
plugins/marketplaces/

# ── Temporary Files ────────────────────────────────────────────────────────────
*.tmp

# ── OS Files ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Worktrees (temporary dev branches) ─────────────────────────────────────────
.worktrees/

# ── What GETS TRACKED ──────────────────────────────────────────────────────────
# rules/                      — Auto rules
# skills/                     — All skills
# agents/                     — All agents
# docs/                       — Documentation
# scripts/                    — Setup scripts
# settings.json.template      — Machine setup template
# README.md, CATALOG.md, CHANGELOG.md — Root docs
# .gitignore                  — This file
